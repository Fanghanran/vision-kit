# ============================================================
# Vision Agent .gitignore
# 安全规则：含密码/密钥的配置、运行数据、日志 不推送到 GitHub
# ============================================================

# ─── 敏感配置（含密码、API Key、摄像头凭据） ───
configs/settings.yaml
.env
.env.*
!.env.example

# ─── 运行数据（截图、视频、数据库） ───
data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.db-journal

# ─── 向量数据库（RAG） ───
chroma_db/
vector_db/
*.chroma

# ─── Redis ───
dump.rdb
*.rdb

# ─── 日志 ───
logs/
*.log
*.log.*

# ─── 模型文件（体积大，不放 Git） ───
models/*.pt
!models/yolov8n.pt
!models/helmet.pt
models/*.onnx
models/*.engine
models/*.pth
models/*.tflite
models/*.bin
models/*.rknn
models/*.xml

# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
.venv/
venv/
env/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
*.so

# ─── Node.js ───
node_modules/
.nuxt/
.next/
.npm
.eslintcache
pnpm-lock.yaml
yarn.lock

# ─── 前端构建产物 ───
vision_agent/web/static/assets/
*.map

# ─── IDE ───
.vscode/
!.vscode/settings.json
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# ─── AI 工具 ───
.claude/
.trae/
.tws/

# ─── 编辑器和备份文件 ───
*.bak
*.tmp
*.orig
*~

# ─── 架构图（临时生成，正式图放 docs/） ───
vision_agent_architecture*.png
vision_agent_architecture*.jpg
vision_agent_architecture*.svg

# ─── 系统文件 ───
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
Icon?
.Spotlight-V100
.Trashes
._*

# ─── Windows ───
*.lnk
*.cab
*.msi
*.msix
*.msm
*.msp

# ─── Docker ───
docker-compose.override.yml

# ─── FFmpeg 临时文件 ───
*.part

# ─── 性能测试结果 ───
benchmarks/
*.prof
*.pstats
cprofile_*

# ─── 前端构建产物 ───
frontend/dist/
